# ─── OS artifacts ────────────────────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.s[w][a-z]
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*
.dir-locals.el

# Sublime Text
*.sublime-workspace
*.sublime-project

# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
dist/
build/
out/
coverage/
*.tsbuildinfo
.eslintcache
.parcel-cache/

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── PairSlash non-authoritative artifacts (auto-generated, pre-write) ────────
.pairslash/sessions/*
!.pairslash/sessions/.gitkeep
.pairslash/staging/*
!.pairslash/staging/.gitkeep
.pairslash/task-memory/*
!.pairslash/task-memory/.gitkeep
.pairslash/install-state/
.pairslash/observability/
.pairslash/tmp/

# ─── Runtime skill install paths (derived from packs/core/) ──────────────────
.agents/skills/
.github/skills/

# ─── Local utility files ──────────────────────────────────────────────────────
.git_commit_msg
.pytest_cache/
