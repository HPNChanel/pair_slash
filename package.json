{
  "name": "pairslash",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/core/*",
    "packages/runtimes/codex/*",
    "packages/runtimes/copilot/*",
    "packages/tools/*"
  ],
  "scripts": {
    "pairslash": "node packages/tools/cli/src/bin/pairslash.js",
    "lint": "node packages/tools/cli/src/bin/pairslash.js lint",
    "test": "node scripts/run-tests.mjs",
    "test:acceptance": "node scripts/run-acceptance-tests.mjs",
    "test:release": "node scripts/run-release-readiness.mjs",
    "test:compat": "node scripts/run-compat-lab-tests.mjs",
    "test:compat:acceptance": "node scripts/run-compat-lab-acceptance.mjs",
    "test:compat:release": "node scripts/run-compat-lab-release-readiness.mjs",
    "sync:compat-lab": "node scripts/sync-compat-lab-artifacts.mjs",
    "release:trust:build": "node scripts/build-release-trust.mjs",
    "release:trust:verify": "node scripts/verify-release-trust.mjs",
    "lint:phase4": "npm run lint",
    "test:phase4": "npm run test:compat",
    "test:phase4:acceptance": "npm run test:compat:acceptance",
    "test:phase4:release": "npm run test:compat:release"
  },
  "dependencies": {
    "valibot": "^1.3.1",
    "yaml": "^2.8.1"
  }
}
